{
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=BusOperatorDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Key": "YOUR_SECRET_KEY",
    "Issuer": "BusOperator",
    "Audience": "BusOperator",
    "AccessTokenMinutes": 480
  },
  "Seed": {
    "Admin": {
      "Username": "admin",
      "Password": "admin123",
      "FullName": "System Admin"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*"
}
